# URL du serveur web SIGT (localhost en local, ou URL Render en production)
SIGT_SERVER_URL=http://localhost:3000

# Clé API pour authentifier le connecteur SUMO auprès du serveur
SUMO_API_KEY=sigt_cotonou_secret_2024

# Chemin relatif ou absolu vers le fichier de configuration de simulation de SUMO
SUMO_CFG=./simulation/stade.sumocfg

# Binaire SUMO à exécuter : 
# "sumo-gui" (avec interface graphique 2D) ou "sumo" (sans interface, plus rapide)
SUMO_BINARY=sumo-gui

# Intervalle de rafraîchissement et d'envoi des données (en secondes)
STEP_INTERVAL=1.0

# Nombre maximum de tentatives si le serveur de réception est déconnecté
RETRY_MAX=5
